{
  "screenName": "home",
  "displayName": "Home",
  "description": "Main dashboard with balance and transactions",
  "version": "1.0.3",
  "contents": {
    "cards": {
    "type": "Column",
    "props": {
        "modifier": {
            "fillMaxWidth": 1.0,
            "padding": {
                "top": 16
            }
        },
        "verticalArrangement": "spacedBy_0"
    },
    "children": [
        {
            "type": "Row",
            "props": {
                "modifier": {
                    "fillMaxWidth": 1.0,
                    "padding": {
                        "horizontal": 20
                    }
                },
                "horizontalArrangement": "spaceBetween",
                "verticalAlignment": "centerVertically"
            },
            "children": [
                {
                    "type": "Text",
                    "props": {
                        "fontSize": 24,
                        "fontWeight": "bold",
                        "color": "@theme/onSurface",
                        "textAlign": "center",
                        "maxLines": 1
                    }
                },
                {
                    "type": "Row",
                    "props": {
                        "horizontalArrangement": "spacedBy_14",
                        "verticalAlignment": "centerVertically"
                    },
                    "children": [
                        {
                            "type": "Component",
                            "props": {
                                "name": "AvatarBadge",
                                "componentName": "AvatarBadge",
                                "properties": {
                                    "initials": "{{data:user:name}}",
                                    "badgeCount": "{{data:user:notificationCount}}",
                                    "size": 48
                                },
                                "props": {
                                    "initials": "{{data:user:name}}",
                                    "badgeCount": "{{data:user:notificationCount}}",
                                    "size": 48
                                }
                            }
                        },
                        {
                            "type": "Column",
                            "props": {
                                "verticalArrangement": "spacedBy_2"
                            },
                            "children": [
                                {
                                    "type": "Text",
                                    "props": {
                                        "text": "{{data:user:name}}",
                                        "fontSize": 20,
                                        "fontWeight": "bold",
                                        "color": "@theme/onSurface"
                                    }
                                }
                            ]
                        }
                    ]
                },
                {
                    "type": "IconButton",
                    "props": {
                        "icon": "notifications_none",
                        "onClick": {
                            "actionType": "callFunction",
                            "functionName": "clearNotifications"
                        },
                        "iconSize": 26,
                        "iconColor": "@theme/onSurface"
                    }
                }
            ]
        },
        {
            "type": "Spacer",
            "props": {
                "height": 20
            }
        },
        {
            "type": "Box",
            "props": {
                "modifier": {
                    "fillMaxWidth": 1.0,
                    "padding": {
                        "horizontal": 20
                    }
                }
            },
            "children": [
                {
                    "type": "Component",
                    "props": {
                        "name": "BalanceDisplay",
                        "componentName": "BalanceDisplay",
                        "properties": {
                            "label": "Total Balance",
                            "amount": "{{data:user:totalBalance}}",
                            "trend": "+12.5% this month",
                            "trendPositive": true
                        },
                        "props": {
                            "label": "Total Balance",
                            "amount": "{{data:user:totalBalance}}",
                            "trend": "+12.5% this month",
                            "trendPositive": true
                        }
                    }
                }
            ]
        },
        {
            "type": "Spacer",
            "props": {
                "height": 20
            }
        },
        {
            "type": "Row",
            "props": {
                "modifier": {
                    "fillMaxWidth": 1.0,
                    "padding": {
                        "horizontal": 20
                    }
                },
                "horizontalArrangement": "spaceEvenly"
            },
            "children": [
                {
                    "type": "Column",
                    "props": {
                        "verticalArrangement": "spacedBy_8",
                        "horizontalAlignment": "centerHorizontally"
                    },
                    "children": [
                        {
                            "type": "Card",
                            "props": {
                                "modifier": {
                                    "size": 64
                                },
                                "shape": "rounded_20",
                                "containerColor": "@theme/primaryContainer",
                                "elevation": 0
                            },
                            "children": [
                                {
                                    "type": "Box",
                                    "props": {
                                        "modifier": {
                                            "fillMaxSize": 1.0
                                        },
                                        "contentAlignment": "center"
                                    },
                                    "children": [
                                        {
                                            "type": "IconButton",
                                            "props": {
                                                "icon": "send",
                                                "onClick": {
                                                    "actionType": "callFunction",
                                                    "functionName": "sendMoney",
                                                    "arguments": {
                                                        "amount": 50.0,
                                                        "recipient": "Alex"
                                                    }
                                                },
                                                "iconSize": 28,
                                                "iconColor": "@theme/primary"
                                            }
                                        }
                                    ]
                                }
                            ]
                        },
                        {
                            "type": "Text",
                            "props": {
                                "text": "Send",
                                "fontSize": 12,
                                "fontWeight": "medium",
                                "color": "@theme/onSurfaceVariant"
                            }
                        }
                    ]
                },
                {
                    "type": "Column",
                    "props": {
                        "verticalArrangement": "spacedBy_8",
                        "horizontalAlignment": "centerHorizontally"
                    },
                    "children": [
                        {
                            "type": "Card",
                            "props": {
                                "modifier": {
                                    "size": 64
                                },
                                "shape": "rounded_20",
                                "containerColor": "@theme/secondaryContainer",
                                "elevation": 0
                            },
                            "children": [
                                {
                                    "type": "Box",
                                    "props": {
                                        "modifier": {
                                            "fillMaxSize": 1.0
                                        },
                                        "contentAlignment": "center"
                                    },
                                    "children": [
                                        {
                                            "type": "IconButton",
                                            "props": {
                                                "icon": "download",
                                                "onClick": {
                                                    "actionType": "callFunction",
                                                    "functionName": "showToast",
                                                    "arguments": {
                                                        "message": "Receive link copied"
                                                    }
                                                },
                                                "iconSize": 28,
                                                "iconColor": "@theme/onSecondaryContainer"
                                            }
                                        }
                                    ]
                                }
                            ]
                        },
                        {
                            "type": "Text",
                            "props": {
                                "text": "Receive",
                                "fontSize": 12,
                                "fontWeight": "medium",
                                "color": "@theme/onSurfaceVariant"
                            }
                        }
                    ]
                },
                {
                    "type": "Column",
                    "props": {
                        "verticalArrangement": "spacedBy_8",
                        "horizontalAlignment": "centerHorizontally"
                    },
                    "children": [
                        {
                            "type": "Card",
                            "props": {
                                "modifier": {
                                    "size": 64
                                },
                                "shape": "rounded_20",
                                "containerColor": "@theme/tertiaryContainer",
                                "elevation": 0
                            },
                            "children": [
                                {
                                    "type": "Box",
                                    "props": {
                                        "modifier": {
                                            "fillMaxSize": 1.0
                                        },
                                        "contentAlignment": "center"
                                    },
                                    "children": [
                                        {
                                            "type": "IconButton",
                                            "props": {
                                                "icon": "swap_horiz",
                                                "onClick": {
                                                    "actionType": "callFunction",
                                                    "functionName": "showToast",
                                                    "arguments": {
                                                        "message": "Swap feature coming soon"
                                                    }
                                                },
                                                "iconSize": 28,
                                                "iconColor": "@theme/onTertiaryContainer"
                                            }
                                        }
                                    ]
                                }
                            ]
                        },
                        {
                            "type": "Text",
                            "props": {
                                "text": "Swap",
                                "fontSize": 12,
                                "fontWeight": "medium",
                                "color": "@theme/onSurfaceVariant"
                            }
                        }
                    ]
                },
                {
                    "type": "Column",
                    "props": {
                        "verticalArrangement": "spacedBy_8",
                        "horizontalAlignment": "centerHorizontally"
                    },
                    "children": [
                        {
                            "type": "Card",
                            "props": {
                                "modifier": {
                                    "size": 64
                                },
                                "shape": "rounded_20",
                                "containerColor": "@theme/surfaceContainerLow",
                                "elevation": 0
                            },
                            "children": [
                                {
                                    "type": "Box",
                                    "props": {
                                        "modifier": {
                                            "fillMaxSize": 1.0
                                        },
                                        "contentAlignment": "center"
                                    },
                                    "children": [
                                        {
                                            "type": "IconButton",
                                            "props": {
                                                "icon": "more_horiz",
                                                "onClick": {
                                                    "actionType": "callFunction",
                                                    "functionName": "showToast",
                                                    "arguments": {
                                                        "message": "More options"
                                                    }
                                                },
                                                "iconSize": 28,
                                                "iconColor": "@theme/onSurfaceVariant"
                                            }
                                        }
                                    ]
                                }
                            ]
                        },
                        {
                            "type": "Text",
                            "props": {
                                "text": "More",
                                "fontSize": 12,
                                "fontWeight": "medium",
                                "color": "@theme/onSurfaceVariant"
                            }
                        }
                    ]
                }
            ]
        },
        {
            "type": "Spacer",
            "props": {
                "height": 24
            }
        },
        {
            "type": "Row",
            "props": {
                "modifier": {
                    "fillMaxWidth": 1.0,
                    "padding": {
                        "horizontal": 20
                    }
                },
                "horizontalArrangement": "spacedBy_12"
            },
            "children": [
                {
                    "type": "Card",
                    "props": {
                        "modifier": {
                            "weight": 1.0
                        },
                        "shape": "rounded_16",
                        "containerColor": "@theme/surface",
                        "elevation": 1
                    },
                    "children": [
                        {
                            "type": "Column",
                            "props": {
                                "modifier": {
                                    "fillMaxWidth": 1.0,
                                    "padding": {
                                        "all": 16
                                    }
                                },
                                "verticalArrangement": "spacedBy_10"
                            },
                            "children": [
                                {
                                    "type": "Row",
                                    "props": {
                                        "modifier": {
                                            "fillMaxWidth": 1.0
                                        },
                                        "horizontalArrangement": "spaceBetween",
                                        "verticalAlignment": "centerVertically"
                                    },
                                    "children": [
                                        {
                                            "type": "Box",
                                            "props": {
                                                "modifier": {
                                                    "size": 40,
                                                    "background": "@theme/successContainer",
                                                    "shape": "rounded_12"
                                                },
                                                "contentAlignment": "center"
                                            },
                                            "children": [
                                                {
                                                    "type": "Icon",
                                                    "props": {
                                                        "icon": "trending_up",
                                                        "size": 22,
                                                        "color": "@theme/success"
                                                    }
                                                }
                                            ]
                                        },
                                        {
                                            "type": "Text",
                                            "props": {
                                                "text": "+8.2%",
                                                "fontSize": 12,
                                                "fontWeight": "bold",
                                                "color": "@theme/success"
                                            }
                                        }
                                    ]
                                },
                                {
                                    "type": "Text",
                                    "props": {
                                        "text": "Income",
                                        "fontSize": 12,
                                        "color": "@theme/onSurfaceVariant"
                                    }
                                },
                                {
                                    "type": "Text",
                                    "props": {
                                        "text": "{{data:user:income}}",
                                        "fontSize": 20,
                                        "fontWeight": "bold",
                                        "color": "@theme/onSurface"
                                    }
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ]
},
    "transactions": {
    "type": "Column",
    "props": {
        "modifier": {
            "fillMaxWidth": 1.0
        },
        "verticalArrangement": "spacedBy_0"
    },
    "children": [
        {
            "type": "Row",
            "props": {
                "modifier": {
                    "fillMaxWidth": 1.0,
                    "padding": {
                        "horizontal": 20
                    }
                },
                "horizontalArrangement": "spaceBetween",
                "verticalAlignment": "centerVertically"
            },
            "children": [
                {
                    "type": "Text",
                    "props": {
                        "text": "Recent Transactions",
                        "fontSize": 17,
                        "fontWeight": "semiBold",
                        "color": "@theme/onSurface"
                    }
                },
                {
                    "type": "Button",
                    "props": {
                        "onClick": {
                            "actionType": "callFunction",
                            "functionName": "showToast",
                            "arguments": {
                                "message": "View all transactions"
                            }
                        },
                        "containerColor": "#00000000",
                        "elevation": 0
                    },
                    "children": [
                        {
                            "type": "Text",
                            "props": {
                                "text": "See All",
                                "fontSize": 13,
                                "fontWeight": "medium",
                                "color": "@theme/primary"
                            }
                        }
                    ]
                }
            ]
        },
        {
            "type": "Spacer",
            "props": {
                "height": 8
            }
        },
        {
            "type": "Column",
            "props": {
                "modifier": {
                    "fillMaxWidth": 1.0,
                    "padding": {
                        "horizontal": 20,
                        "bottom": 16
                    }
                },
                "verticalArrangement": "spacedBy_8"
            },
            "children": [
                {
                    "type": "DataList",
                    "props": {
                        "dataSource": "user.transactions",
                        "itemAlias": "txn"
                    },
                    "children": [
                        {
                            "type": "Component",
                            "props": {
                                "name": "TransactionRow",
                                "componentName": "TransactionRow",
                                "properties": {
                                    "title": "{{data:txn:title}}",
                                    "subtitle": "{{data:txn:subtitle}}",
                                    "amount": "{{data:txn:amount}}",
                                    "isIncome": "{{data:txn:isIncome}}"
                                },
                                "props": {
                                    "title": "{{data:txn:title}}",
                                    "subtitle": "{{data:txn:subtitle}}",
                                    "amount": "{{data:txn:amount}}",
                                    "isIncome": "{{data:txn:isIncome}}"
                                }
                            }
                        }
                    ]
                }
            ]
        }
    ]
}
  }
}