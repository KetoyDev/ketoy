{
  "screenName": "history_screen",
  "displayName": "History",
  "description": "Full transaction history",
  "version": "1.0.0",
  "contents": {
    "main": {
    "type": "Column",
    "props": {
        "modifier": {
            "fillMaxSize": 1.0,
            "padding": {
                "top": 16
            },
            "background": "@theme/background"
        },
        "verticalArrangement": "spacedBy_0"
    },
    "children": [
        {
            "type": "Text",
            "props": {
                "fontSize": 20
            }
        },
        {
            "type": "Row",
            "props": {
                "modifier": {
                    "fillMaxWidth": 1.0,
                    "padding": {
                        "horizontal": 20
                    }
                },
                "horizontalArrangement": "spaceBetween",
                "verticalAlignment": "centerVertically"
            },
            "children": [
                {
                    "type": "Text",
                    "props": {
                        "text": "Transaction History",
                        "fontSize": 24,
                        "fontWeight": "bold",
                        "color": "@theme/onSurface"
                    }
                },
                {
                    "type": "IconButton",
                    "props": {
                        "icon": "filter_list",
                        "onClick": {
                            "actionType": "callFunction",
                            "functionName": "showToast",
                            "arguments": {
                                "message": "Filter options"
                            }
                        },
                        "iconSize": 24,
                        "iconColor": "@theme/onSurfaceVariant"
                    }
                }
            ]
        },
        {
            "type": "Spacer",
            "props": {
                "height": 16
            }
        },
        {
            "type": "Box",
            "props": {
                "modifier": {
                    "fillMaxWidth": 1.0,
                    "padding": {
                        "horizontal": 20
                    }
                }
            },
            "children": [
                {
                    "type": "Card",
                    "props": {
                        "modifier": {
                            "fillMaxWidth": 1.0
                        },
                        "shape": "rounded_16",
                        "containerColor": "@theme/surfaceContainerLow",
                        "elevation": 0,
                        "onClick": {
                            "actionType": "callFunction",
                            "functionName": "showToast",
                            "arguments": {
                                "message": "Search transactions"
                            }
                        }
                    },
                    "children": [
                        {
                            "type": "Row",
                            "props": {
                                "modifier": {
                                    "fillMaxWidth": 1.0,
                                    "padding": {
                                        "horizontal": 16,
                                        "vertical": 14
                                    }
                                },
                                "horizontalArrangement": "spacedBy_12",
                                "verticalAlignment": "centerVertically"
                            },
                            "children": [
                                {
                                    "type": "Icon",
                                    "props": {
                                        "icon": "search",
                                        "size": 22,
                                        "color": "@theme/outline"
                                    }
                                },
                                {
                                    "type": "Text",
                                    "props": {
                                        "text": "Search transactions...",
                                        "fontSize": 15,
                                        "color": "@theme/outline"
                                    }
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        {
            "type": "Spacer",
            "props": {
                "height": 20
            }
        },
        {
            "type": "Row",
            "props": {
                "modifier": {
                    "fillMaxWidth": 1.0,
                    "padding": {
                        "horizontal": 20
                    }
                },
                "horizontalArrangement": "spacedBy_8"
            },
            "children": [
                {
                    "type": "Card",
                    "props": {
                        "modifier": {
                            "height": 34
                        },
                        "shape": "rounded_50",
                        "containerColor": "@theme/primary",
                        "elevation": 0,
                        "onClick": {
                            "actionType": "callFunction",
                            "functionName": "showToast",
                            "arguments": {
                                "message": "All filter"
                            }
                        }
                    },
                    "children": [
                        {
                            "type": "Box",
                            "props": {
                                "modifier": {
                                    "fillMaxHeight": 1.0,
                                    "padding": {
                                        "horizontal": 16
                                    }
                                },
                                "contentAlignment": "center"
                            },
                            "children": [
                                {
                                    "type": "Text",
                                    "props": {
                                        "text": "All",
                                        "fontSize": 13,
                                        "fontWeight": "medium",
                                        "color": "@theme/onPrimary"
                                    }
                                }
                            ]
                        }
                    ]
                },
                {
                    "type": "Card",
                    "props": {
                        "modifier": {
                            "height": 34
                        },
                        "shape": "rounded_50",
                        "containerColor": "@theme/surfaceContainerLow",
                        "elevation": 0,
                        "onClick": {
                            "actionType": "callFunction",
                            "functionName": "showToast",
                            "arguments": {
                                "message": "Income filter"
                            }
                        }
                    },
                    "children": [
                        {
                            "type": "Box",
                            "props": {
                                "modifier": {
                                    "fillMaxHeight": 1.0,
                                    "padding": {
                                        "horizontal": 16
                                    }
                                },
                                "contentAlignment": "center"
                            },
                            "children": [
                                {
                                    "type": "Text",
                                    "props": {
                                        "text": "Income",
                                        "fontSize": 13,
                                        "fontWeight": "medium",
                                        "color": "@theme/onSurfaceVariant"
                                    }
                                }
                            ]
                        }
                    ]
                },
                {
                    "type": "Card",
                    "props": {
                        "modifier": {
                            "height": 34
                        },
                        "shape": "rounded_50",
                        "containerColor": "@theme/surfaceContainerLow",
                        "elevation": 0,
                        "onClick": {
                            "actionType": "callFunction",
                            "functionName": "showToast",
                            "arguments": {
                                "message": "Expense filter"
                            }
                        }
                    },
                    "children": [
                        {
                            "type": "Box",
                            "props": {
                                "modifier": {
                                    "fillMaxHeight": 1.0,
                                    "padding": {
                                        "horizontal": 16
                                    }
                                },
                                "contentAlignment": "center"
                            },
                            "children": [
                                {
                                    "type": "Text",
                                    "props": {
                                        "text": "Expense",
                                        "fontSize": 13,
                                        "fontWeight": "medium",
                                        "color": "@theme/onSurfaceVariant"
                                    }
                                }
                            ]
                        }
                    ]
                },
                {
                    "type": "Card",
                    "props": {
                        "modifier": {
                            "height": 34
                        },
                        "shape": "rounded_50",
                        "containerColor": "@theme/surfaceContainerLow",
                        "elevation": 0,
                        "onClick": {
                            "actionType": "callFunction",
                            "functionName": "showToast",
                            "arguments": {
                                "message": "Pending filter"
                            }
                        }
                    },
                    "children": [
                        {
                            "type": "Box",
                            "props": {
                                "modifier": {
                                    "fillMaxHeight": 1.0,
                                    "padding": {
                                        "horizontal": 16
                                    }
                                },
                                "contentAlignment": "center"
                            },
                            "children": [
                                {
                                    "type": "Text",
                                    "props": {
                                        "text": "Pending",
                                        "fontSize": 13,
                                        "fontWeight": "medium",
                                        "color": "@theme/onSurfaceVariant"
                                    }
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        {
            "type": "Spacer",
            "props": {
                "height": 16
            }
        },
        {
            "type": "Text",
            "props": {
                "text": "February 2025",
                "modifier": {
                    "padding": {
                        "horizontal": 20,
                        "bottom": 8
                    }
                },
                "fontSize": 13,
                "fontWeight": "semiBold",
                "color": "@theme/onSurfaceVariant"
            }
        },
        {
            "type": "Column",
            "props": {
                "modifier": {
                    "fillMaxWidth": 1.0,
                    "padding": {
                        "horizontal": 20,
                        "bottom": 16
                    }
                },
                "verticalArrangement": "spacedBy_8"
            },
            "children": [
                {
                    "type": "DataList",
                    "props": {
                        "dataSource": "user.transactions",
                        "itemAlias": "txn"
                    },
                    "children": [
                        {
                            "type": "Component",
                            "props": {
                                "name": "TransactionRow",
                                "componentName": "TransactionRow",
                                "properties": {
                                    "title": "{{data:txn:title}}",
                                    "subtitle": "{{data:txn:subtitle}}",
                                    "amount": "{{data:txn:amount}}",
                                    "isIncome": "{{data:txn:isIncome}}"
                                },
                                "props": {
                                    "title": "{{data:txn:title}}",
                                    "subtitle": "{{data:txn:subtitle}}",
                                    "amount": "{{data:txn:amount}}",
                                    "isIncome": "{{data:txn:isIncome}}"
                                }
                            }
                        }
                    ]
                }
            ]
        },
        {
            "type": "Spacer",
            "props": {
                "height": 8
            }
        },
        {
            "type": "Box",
            "props": {
                "modifier": {
                    "fillMaxWidth": 1.0,
                    "padding": {
                        "horizontal": 20,
                        "bottom": 16
                    }
                },
                "contentAlignment": "center"
            },
            "children": [
                {
                    "type": "Card",
                    "props": {
                        "shape": "rounded_50",
                        "containerColor": "@theme/primary",
                        "elevation": 4,
                        "onClick": {
                            "actionType": "callFunction",
                            "functionName": "addTransaction",
                            "arguments": {
                                "title": "New Purchase",
                                "amount": 25.0,
                                "isIncome": false
                            }
                        }
                    },
                    "children": [
                        {
                            "type": "Row",
                            "props": {
                                "modifier": {
                                    "padding": {
                                        "horizontal": 20,
                                        "vertical": 12
                                    }
                                },
                                "horizontalArrangement": "spacedBy_8",
                                "verticalAlignment": "centerVertically"
                            },
                            "children": [
                                {
                                    "type": "Icon",
                                    "props": {
                                        "icon": "add",
                                        "size": 20,
                                        "color": "@theme/onPrimary"
                                    }
                                },
                                {
                                    "type": "Text",
                                    "props": {
                                        "text": "Add Transaction",
                                        "fontSize": 14,
                                        "fontWeight": "semiBold",
                                        "color": "@theme/onPrimary"
                                    }
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ]
}
  }
}