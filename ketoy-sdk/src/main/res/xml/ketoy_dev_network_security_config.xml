<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Configuration for Ketoy Dev Tools.

  Allows cleartext (HTTP) traffic exclusively to the Ketoy Dev Server hosts:
    • 10.0.2.2  — Android Emulator's standard alias for the host machine loopback.
    • localhost  — Works via `adb reverse` when running on an emulator.
    • 127.0.0.1  — Explicit loopback alias.

  These addresses are only reachable during local development and are never
  exposed to the public internet, so cleartext is acceptable here.

  If your app already has a networkSecurityConfig, remove the manifest reference
  to this file (android:networkSecurityConfig in the SDK's manifest) and instead
  add the <domain-config> block below directly into your own config:

    <domain-config cleartextTrafficPermitted="true">
        <domain>10.0.2.2</domain>
        <domain>localhost</domain>
        <domain>127.0.0.1</domain>
    </domain-config>
-->
<network-security-config>

    <!-- Ketoy Dev Server hosts — cleartext HTTP is intentional here -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>

</network-security-config>
